rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ─── Allow reads/writes to aiRecommendations subcollection ──
    match /fields/{fieldId}/blocks/{blockId}/rows/{rowId}/plants/{plantId}/aiRecommendations/{docId} {
      allow read, write: if request.auth != null;
    }
    // ─── Legacy support (fields without blocks) ──────────────
    match /fields/{fieldId}/rows/{rowId}/plants/{plantId}/aiRecommendations/{docId} {
      allow read, write: if request.auth != null;
    }
  }
}
